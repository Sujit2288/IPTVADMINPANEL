{
  "entities": {
    "User": {
      "title": "User",
      "description": "An IPTV user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "macAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "EXPIRED", "PENDING", "DENIED"] },
        "expiryDate": { "type": "string", "format": "date" },
        "packageId": { "type": "string" },
        "packageName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "macAddress", "status"]
    },
    "Package": {
      "title": "Package",
      "description": "A subscription package",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "validityDays": { "type": "integer" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "validityDays"]
    },
    "Channel": {
      "title": "Channel",
      "description": "An IPTV channel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["name", "url", "categoryId"]
    },
    "Category": {
      "title": "Category",
      "description": "A channel category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrator",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Collection of IPTV users" },
    "/packages/{packageId}": { "schema": "Package", "description": "Collection of subscription packages" },
    "/channels/{channelId}": { "schema": "Channel", "description": "Collection of IPTV channels" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Collection of channel categories" },
    "/admins/{adminId}": { "schema": "Admin", "description": "Collection of administrators" }
  }
}
